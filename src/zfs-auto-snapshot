#!/bin/bash
#  shellcheck disable=2001  ## 'See if you can use ${variable//search/replace} instead.' Complains about good uses of sed.
#  shellcheck disable=2016  ## 'Expressions don't expand in single quotes, use double quotes for that.' I know, and I often want an explicit '$'.
#  shellcheck disable=2034  ## 'variable appears unused.' Complains about valid use of variable indirection (e.g. later use of local -n var=$1)
#  shellcheck disable=2046  ## 'Quote to prevent word-splitting.' (OK for integers.)
#  shellcheck disable=2048  ## 'Use "$@" (with quotes).' print_log intentionally word-splits $* so 'echo $*' space-joins the message (quoting would join on IFS, now a tab).
#  shellcheck disable=2086  ## 'Double quote to prevent globbing and word splitting.' (OK for integers.)
#  shellcheck disable=2119  ## 'Use foo "$@" if function's $1 should mean script's $1.' Confusing and inapplicable.
#  shellcheck disable=2120  ## 'Foo references arguments, but none are ever passed.' Valid function argument overloading.
#  shellcheck disable=2128  ## 'Expanding an array without an index only gives the element in the index 0.' False hits on associative arrays.
#  shellcheck disable=2155  ## 'Declare and assign separately to avoid masking return values.' Cumbersome and unnecessary.
#  shellcheck disable=2178  ## 'Variable was used as an array but is now assigned a string.' False hits on associative arrays with e.g. 'local -n assocArray=$1'.
#  shellcheck disable=2317  ## 'Can't reach.' I.e. an 'exit' is used for debugging and makes a visual mess.
## shellcheck disable=2002  ## 'Useless use of cat.'
## shellcheck disable=2004  ## '$/${} is unnecessary on arithmetic variables.' Inappropriate complaining?
## shellcheck disable=2053  ## 'Quote the right-hand sid of = in [[ ]] to prevent glob matching.' Disable for valid Yoda Notation warning?
## shellcheck disable=2143  ## 'Use grep -q instead of echo | grep'
## shellcheck disable=2162  ## 'read without -r will mangle backslashes.'
## shellcheck disable=2181  ## 'Check exit code directly, not indirectly with $?.'


##	Purpose:
##		Automatically create, rotate, and destroy periodic ZFS snapshots.
##		Part of a ZFS snapshot auto-creation and pruning system (that also includes cron.d scripts).
##	History: At bottom of script. Change log at <https://github.com/jim-collier/zfs-auto-snapshot>.
##	Notes:
##		- Minimum Bash version: 3.2 (no associative arrays, namerefs, 'declare -g', '[[ -v ]]', '${var,,}', or inherit_errexit).
##	Version: v2.0.0 build 1n48pxn.

##	Copyright 2011 Darik Horn <dajhorn@vanadac.com>
##	Copyright 2026 Jim Collier <-wneGcMGaw-1HuTBMeQagUP2zmBhL18HZh1KRYH5eis=>
##		- Changes: See 'History' below, and
##	SPDX-License-Identifier: GPL-2.0-only


## Fail fast and loud. No inherit_errexit (Bash 4.4+); the command substitutions
## below each carry their own '|| { ...; exit; }' so errors are still caught.
set -o errexit   #..: Abort on any uncaught command failure.
set -o nounset   #..: Unset variable use is an error.
set -o pipefail  #..: A pipeline fails if any stage fails.

## Split words on tab and newline only - never on spaces. Target lists are joined
## with a tab (see $TAB) and 'zfs list -H' uses tabs between columns, so both the
## target loop and the 'read NAME PROPERTIES' arg check depend on tab being here.
IFS=$'\t\n'
TAB=$'\t'

## Default program options.
opt_backup_full=''
opt_backup_incremental=''
opt_debug=''
opt_default_exclude=''
opt_dry_run=''
opt_event='-'
opt_fast_zfs_list=''
opt_keep=''
opt_label=''
opt_prefix='zfs-auto-snap'
opt_quiet=''
opt_recursive=''
opt_sep='_'
opt_setauto=''
opt_syslog=''
opt_skip_scrub=''
opt_verbose=''
opt_pre_snapshot=''
opt_post_snapshot=''
opt_do_snapshots=1
opt_min_size=0

## Global summary statistics.
DESTRUCTION_COUNT=0
SNAPSHOT_COUNT=0
WARNING_COUNT=0

## Other globals.
SNAPSHOTS_OLD=''


print_usage(){
	echo "Usage: $0 [options] [-l label] <'//' | name [name...]>
  --default-exclude  Exclude datasets if com.sun:auto-snapshot is unset.
  -d, --debug        Print debugging messages.
  -e, --event=EVENT  Set the com.sun:auto-snapshot-desc property to EVENT.
      --fast         Use a faster zfs list invocation.
  -n, --dry-run      Print actions without actually doing anything.
  -s, --skip-scrub   Do not snapshot filesystems in scrubbing pools.
  -h, --help         Print this usage message.
  -k, --keep=NUM     Keep NUM recent snapshots and destroy older snapshots.
  -l, --label=LAB    LAB is usually 'hourly', 'daily', or 'monthly'.
  -m, --min-size=KB  Skip a dataset if < KB written since its last snapshot.
  -p, --prefix=PRE   PRE is 'zfs-auto-snap' by default.
  -q, --quiet        Suppress warnings and notices at the console.
      --send-full=F  Send zfs full backup. Unimplemented.
      --send-incr=F  Send zfs incremental backup. Unimplemented.
      --sep=CHAR     Use CHAR to separate date stamps in snapshot names.
  -g, --syslog       Write messages into the system log.
  -r, --recursive    Snapshot named filesystem and all descendants.
  -v, --verbose      Print info messages.
      --destroy-only Only destroy older snapshots, do not create new ones.
      name           Filesystem and volume names, or '//' for all ZFS datasets.
"
}


print_log(){  # level, message...
	local level="$1"; shift
	## Logging must never abort the run, so 'logger' is guarded and we always
	## return 0 (a false guard test would otherwise trip errexit at the caller).
	case "$level" in
		eme*) [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" -p daemon.emerge $* || true; }
		      echo "Emergency: $*" 1>&2 ;;
		ale*) [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" -p daemon.alert $* || true; }
		      echo "Alert: $*" 1>&2 ;;
		cri*) [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" -p daemon.crit $* || true; }
		      echo "Critical: $*" 1>&2 ;;
		err*) [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" -p daemon.err $* || true; }
		      echo "Error: $*" 1>&2 ;;
		war*) [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" -p daemon.warning $* || true; }
		      [[ -z "$opt_quiet" ]] && echo "Warning: $*" 1>&2 ;;
		not*) [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" -p daemon.notice $* || true; }
		      [[ -z "$opt_quiet" ]] && echo $* ;;
		inf*) [[ -z "$opt_quiet" && -n "$opt_verbose" ]] && echo $* ;;
		deb*) [[ -n "$opt_debug" ]] && echo "Debug: $*" ;;
		*)    [[ -n "$opt_syslog" ]] && { logger -t "$opt_prefix" $* || true; }
		       echo $* 1>&2 ;;
	esac
	return 0
}


do_run(){  # command-string
	## Run (or, in a dry run, just print) a command and report its exit code.
	## 'eval ... || rc=$?' captures failure without tripping errexit, regardless
	## of the caller's context.
	local rc=0
	if [[ -n "$opt_dry_run" ]]; then
		echo "$*"
		return 0
	fi
	eval "$*" || rc=$?
	if (( rc == 0 )); then
		print_log debug "$*"
	else
		print_log warning "$* returned $rc"
	fi
	return "$rc"
}


do_snapshots(){  # props, flags, snapname, oldglob, targets
	local props="$1" flags="$2" name="$3" glob="$4" targets="$5"
	local ii jj keep runsnap kb_written bytes_written
	## Tallies into globals DESTRUCTION_COUNT, SNAPSHOT_COUNT, WARNING_COUNT; reads SNAPSHOTS_OLD.

	for ii in $targets; do
		runsnap=1

		## --min-size: skip if too little has been written since the last snapshot
		## (kB; 0 disables). A failed 'zfs get' counts as 0 written.
		local size_check_skip=0
		if (( opt_min_size > 0 )); then
			bytes_written=$(zfs get -Hp -o value written "$ii" 2>/dev/null) || bytes_written=0
			kb_written=$(( bytes_written / 1024 ))
			if (( kb_written < opt_min_size )); then
				size_check_skip=1
				print_log info "Skipping target $ii, only $kb_written kB written since last snap. opt_min_size is $opt_min_size"
			fi
		fi

		if [[ -n "$opt_do_snapshots" ]] && (( ! size_check_skip )); then
			[[ -n "$opt_pre_snapshot" ]] && { do_run "$opt_pre_snapshot $ii $name" || runsnap=0; }
			if (( runsnap )) && do_run "zfs snapshot $props $flags '$ii@$name'"; then
				[[ -n "$opt_post_snapshot" ]] && { do_run "$opt_post_snapshot $ii $name" || true; }
				(( ++SNAPSHOT_COUNT ))
			else
				(( ++WARNING_COUNT ))
				continue
			fi
		fi

		## Retain at most $opt_keep recent snapshots of this dataset (counting the
		## one just made); destroy older ones.
		[[ -n "$opt_keep" ]] || continue
		keep="$opt_keep"

		## SNAPSHOTS_OLD is sorted newest-first, so the first $opt_keep matches stay.
		for jj in $SNAPSHOTS_OLD; do
			## Is jj an old snapshot of this dataset matching our label glob?
			if [[ -z "${jj#$ii@$glob}" ]]; then
				keep=$(( keep - 1 ))
				if (( keep <= 0 )); then
					if do_run "zfs destroy -d $flags '$jj'"; then
						(( ++DESTRUCTION_COUNT ))
					else
						(( ++WARNING_COUNT ))
					fi
				fi
			fi
		done
	done
	return 0
}


## Darwin ships BSD getopt; prefer Homebrew's GNU getopt if present. Darwin is not
## a supported target, but this is kept for ancestral parity with zfsonlinux.
if [[ "$(uname)" == "Darwin" ]]; then
	GETOPT_BIN="$(brew --prefix gnu-getopt 2>/dev/null || echo /usr/local)/bin/getopt"
else
	GETOPT_BIN="getopt"
fi

GETOPT=$("$GETOPT_BIN" \
  --longoptions=default-exclude,dry-run,fast,skip-scrub,recursive \
  --longoptions=event:,keep:,label:,prefix:,sep: \
  --longoptions=debug,help,quiet,syslog,verbose \
  --longoptions=pre-snapshot:,post-snapshot:,destroy-only \
  --longoptions=min-size: \
  --options=dnshe:l:k:p:rs:qgvm: \
  -- "$@") \
  || exit 128

eval set -- "$GETOPT"

while (( $# > 0 )); do
	case "$1" in
		(-d|--debug)
			opt_debug='1'
			opt_quiet=''
			opt_verbose='1'
			shift 1 ;;
		(--default-exclude)
			opt_default_exclude='1'
			shift 1 ;;
		(-e|--event)
			if (( ${#2} > 1024 )); then
				print_log error "The $1 parameter must be less than 1025 characters."
				exit 139
			elif (( ${#2} > 0 )); then
				opt_event="$2"
			fi
			shift 2 ;;
		(--fast)
			opt_fast_zfs_list='1'
			shift 1 ;;
		(-n|--dry-run)
			opt_dry_run='1'
			shift 1 ;;
		(-s|--skip-scrub)
			opt_skip_scrub='1'
			shift 1 ;;
		(-h|--help)
			print_usage
			exit 0 ;;
		(-k|--keep)
			if ! test "$2" -gt 0 2>/dev/null; then
				print_log error "The $1 parameter must be a positive integer."
				exit 129
			fi
			opt_keep="$2"
			shift 2 ;;
		(-l|--label)
			opt_label="$2"
			shift 2 ;;
		(-m|--min-size)
			opt_min_size="$2"
			shift 2 ;;
		(-p|--prefix)
			## Reject any non-alphanumeric (allowing _ . : space -) character.
			opt_prefix="$2"
			while (( ${#opt_prefix} > 0 )); do
				case $opt_prefix in
					([![:alnum:]_.:\ -]*)
						print_log error "The $1 parameter must be alphanumeric."
						exit 130 ;;
				esac
				opt_prefix="${opt_prefix#?}"
			done
			opt_prefix="$2"
			shift 2 ;;
		(-q|--quiet)
			opt_debug=''
			opt_quiet='1'
			opt_verbose=''
			shift 1 ;;
		(-r|--recursive)
			opt_recursive='1'
			shift 1 ;;
		(--sep)
			case "$2" in
				([[:alnum:]_.:\ -]) : ;;
				('')
					print_log error "The $1 parameter must be non-empty."
					exit 131 ;;
				(*)
					print_log error "The $1 parameter must be one alphanumeric character."
					exit 132 ;;
			esac
			opt_sep="$2"
			shift 2 ;;
		(-g|--syslog)
			opt_syslog='1'
			shift 1 ;;
		(-v|--verbose)
			opt_quiet=''
			opt_verbose='1'
			shift 1 ;;
		(--pre-snapshot)
			opt_pre_snapshot="$2"
			shift 2 ;;
		(--post-snapshot)
			opt_post_snapshot="$2"
			shift 2 ;;
		(--destroy-only)
			opt_do_snapshots=''
			shift 1 ;;
		(--)
			shift 1
			break ;;
	esac
done

if (( $# == 0 )); then
	print_log error "The filesystem argument list is empty."
	exit 133
fi

## The '//' wildcard, if given, must be the only argument.
## (if-block, not '[[ ]] && (( ))', so the loop never ends on a false test under errexit.)
SLASHIES=0
for ii in "$@"; do
	if [[ "$ii" == '//' ]]; then (( ++SLASHIES )); fi
done
if (( $# > 1 && SLASHIES > 0 )); then
	print_log error "The // must be the only argument if it is given."
	exit 134
fi

## These are the only times that 'zpool status' or 'zfs list' are invoked, so this
## program for Linux has a much better runtime complexity than the Solaris original.

ZPOOL_STATUS=$(env LC_ALL=C zpool status 2>&1) \
  || { print_log error "zpool status $?: $ZPOOL_STATUS"; exit 135; }

ZFS_LIST=$(env LC_ALL=C zfs list -H -t filesystem,volume -s name \
  -o name,com.sun:auto-snapshot,com.sun:auto-snapshot:"$opt_label") \
  || { print_log error "zfs list $?: $ZFS_LIST"; exit 136; }

if [[ -n "$opt_fast_zfs_list" ]]; then
	## Date now leads the snapshot name, so a plain reverse name sort yields
	## newest-first within each dataset - no need to extract a trailing stamp.
	## 'grep' finding nothing (exit 1) is normal (no old snapshots yet); only a
	## real grep error (exit 2) should fail the pipeline.
	SNAPSHOTS_OLD=$(env LC_ALL=C zfs list -H -t snapshot -o name \
		| { grep "$opt_prefix" || (( $? == 1 )); } \
		| sort -r) \
	  || { print_log error "zfs list $?: $SNAPSHOTS_OLD"; exit 137; }
else
	SNAPSHOTS_OLD=$(env LC_ALL=C zfs list -H -t snapshot -S creation -o name) \
	  || { print_log error "zfs list $?: $SNAPSHOTS_OLD"; exit 137; }
fi

## Verify that each named argument is a filesystem or volume.
for ii in "$@"; do
	[[ "$ii" == '//' ]] && continue 1
	## Inverted test (|| continue) so the loop body returns 0 on a non-match - a
	## trailing false '[[ ]] && continue' would otherwise trip errexit.
	while read NAME PROPERTIES; do
		[[ "$ii" != "$NAME" ]] || continue 2
	done <<-HERE
	$ZFS_LIST
	HERE
	print_log error "$ii is not a ZFS filesystem or volume."
	exit 138
done

## Pools currently being scrubbed.
ZPOOLS_SCRUBBING=$(echo "$ZPOOL_STATUS" | awk -F ': ' \
  '$1 ~ /^ *pool$/ { pool = $2 } ; \
   $1 ~ /^ *scan$/ && $2 ~ /scrub in progress/ { print pool }' \
  | sort)

## Pools that cannot currently take a snapshot.
ZPOOLS_NOTREADY=$(echo "$ZPOOL_STATUS" | awk -F ': ' \
  '$1 ~ /^ *pool$/ { pool = $2 } ; \
   $1 ~ /^ *state$/ && $2 !~ /ONLINE|DEGRADED/ { print pool } ' \
  | sort)

## Datasets for which snapshots are explicitly disabled.
NOAUTO=$(echo "$ZFS_LIST" | awk -F '\t' \
  'tolower($2) ~ /false/ || tolower($3) ~ /false/ {print $1}')

## With --default-exclude, include only datasets explicitly opted in; otherwise
## include everything not explicitly opted out.
if [[ -n "$opt_default_exclude" ]]; then
	CANDIDATES=$(echo "$ZFS_LIST" | awk -F '\t' \
	  'tolower($2) ~ /true/ || tolower($3) ~ /true/ {print $1}')
else
	CANDIDATES=$(echo "$ZFS_LIST" | awk -F '\t' \
	  'tolower($2) !~ /false/ && tolower($3) !~ /false/ {print $1}')
fi

## Datasets that will get a recursive, and a non-recursive, snapshot.
TARGETS_RECURSIVE=''
TARGETS_REGULAR=''

for ii in $CANDIDATES; do
	## Qualify names with a trailing '/' so prefix tests don't false-match
	## (e.g. 'tank' must not look like a prefix of 'tanker/foo').
	iii="$ii/"

	## Exclude datasets not named on the command line.
	IN_ARGS=0
	for jj in "$@"; do
		if [[ "$jj" == '//' || "$jj" == "$ii" ]]; then (( ++IN_ARGS )); fi
	done
	(( IN_ARGS == 0 )) && continue

	## Exclude datasets in pools that cannot snapshot.
	for jj in $ZPOOLS_NOTREADY; do
		jjj="$jj/"
		if [[ "$iii" != "${iii#$jjj}" ]]; then
			print_log info "Excluding $ii because pool $jj is not ready."
			continue 2
		fi
	done

	## With --skip-scrub, exclude datasets in scrubbing pools.
	if [[ -n "$opt_skip_scrub" ]]; then
		for jj in $ZPOOLS_SCRUBBING; do
			jjj="$jj/"
			if [[ "$iii" != "${iii#$jjj}" ]]; then
				print_log info "Excluding $ii because pool $jj is scrubbing."
				continue 2
			fi
		done
	fi

	for jj in $NOAUTO; do
		jjj="$jj/"
		## --recursive only matters for non-wild arguments.
		if [[ -z "$opt_recursive" && "$1" != '//' ]]; then
			print_log debug "Including $ii for regular snapshot."
			TARGETS_REGULAR="${TARGETS_REGULAR:+$TARGETS_REGULAR$TAB}$ii"
			continue 2
		## Snapshot non-recursively if an excluded dataset sits below this one.
		elif [[ "$jjj" != "${jjj#$iii}" ]]; then
			print_log debug "Including $ii for regular snapshot."
			TARGETS_REGULAR="${TARGETS_REGULAR:+$TARGETS_REGULAR$TAB}$ii"
			continue 2
		fi
	done

	for jj in $TARGETS_RECURSIVE; do
		jjj="$jj/"
		## Skip if an already-included dataset covers this one recursively.
		if [[ "$iii" != "${iii#$jjj}" ]]; then
			print_log debug "Excluding $ii because $jj includes it recursively."
			continue 2
		fi
	done

	## This candidate has no exclusionary property, is in a snapshottable pool,
	## has no excluded descendant, and is not under an already-included dataset.
	print_log debug "Including $ii for recursive snapshot."
	TARGETS_RECURSIVE="${TARGETS_RECURSIVE:+$TARGETS_RECURSIVE$TAB}$ii"
done

## Linux lacks SMF and FMRI events, but set this property anyway because the SUNW
## program does. The dash character is the default.
SNAPPROP="-o com.sun:auto-snapshot-desc='$opt_event'"

## Local date/time, leading the snapshot name so a plain name sort is chronological.
## Fifteen characters: YYYYmmDD-HHMMSS. No %z offset - '+' is invalid in a ZFS name,
## and pruning orders by real creation time (or by this leading stamp under --fast).
DATE=$(date +%Y%m%d-%H%M%S)

## The snapshot name after the @ symbol.
SNAPNAME="${DATE}_$opt_prefix${opt_label:+$opt_sep$opt_label}"

## Glob matching old snapshots: 15 '?' for the leading YYYYmmDD-HHMMSS stamp.
SNAPGLOB="???????????????_$opt_prefix${opt_label:+$opt_sep$opt_label}"

if [[ -n "$opt_do_snapshots" ]]; then
	[[ -n "$TARGETS_REGULAR" ]]   && print_log info "Doing regular snapshots of $TARGETS_REGULAR"
	[[ -n "$TARGETS_RECURSIVE" ]] && print_log info "Doing recursive snapshots of $TARGETS_RECURSIVE"
	if [[ -n "$opt_keep" ]] && (( opt_keep >= 1 )); then
		print_log info "Destroying all but the newest $opt_keep snapshots of each dataset."
	fi
elif [[ -n "$opt_keep" ]] && (( opt_keep >= 1 )); then
	[[ -n "$TARGETS_REGULAR" ]]   && print_log info "Destroying all but the newest $opt_keep snapshots of $TARGETS_REGULAR"
	[[ -n "$TARGETS_RECURSIVE" ]] && print_log info "Recursively destroying all but the newest $opt_keep snapshots of $TARGETS_RECURSIVE"
else
	print_log notice "Only destroying snapshots, but count of snapshots to preserve not given. Nothing to do."
fi

[[ -n "$opt_dry_run" ]] && print_log info "Doing a dry run. Not running these commands..."

do_snapshots "$SNAPPROP" ""   "$SNAPNAME" "$SNAPGLOB" "$TARGETS_REGULAR"
do_snapshots "$SNAPPROP" "-r" "$SNAPNAME" "$SNAPGLOB" "$TARGETS_RECURSIVE"

print_log notice "@$SNAPNAME," \
  "$SNAPSHOT_COUNT created," \
  "$DESTRUCTION_COUNT destroyed," \
  "$WARNING_COUNT warnings."

exit 0


